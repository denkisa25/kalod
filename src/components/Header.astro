---
import { pad } from '../lib/format';
import { withBase } from '../lib/url';

interface Props {
  current?: 'work' | 'about' | 'contacts';
  /** CR-3/D1: the home page starts in the large-centered-on-load state and
   *  shrinks once scrolled past cue 01. work/about/contacts and the 48
   *  project pages now render permanently large too (client direction,
   *  post-CR-001) — no #cue-0 on those pages, so header-scroll.ts's
   *  IntersectionObserver never attaches and it just stays large. */
  hero?: boolean;
  /** CR-3/D1's nav/sound fade only makes sense for the home page's BRIEF
   *  large-logo moment (scrolling reveals full-opacity nav a second later).
   *  Pages that render large permanently keep nav fully visible — it's
   *  their primary way to navigate, not a few seconds before it fades in. */
  dimNavWhileHero?: boolean;
}
const { current, hero = false, dimNavWhileHero = false } = Astro.props;

const links: Array<{ href: string; label: 'work' | 'about' | 'contacts' }> = [
  { href: withBase('/work'), label: 'work' },
  { href: withBase('/about'), label: 'about' },
  { href: withBase('/contacts'), label: 'contacts' },
];
const headerClass = [hero ? 'header--hero' : 'header--compact', hero && dimNavWhileHero && 'header--dim-nav']
  .filter(Boolean)
  .join(' ');
---
<header class={headerClass}>
  <a class="brand" href={withBase('/')}>kaloyan dimitrov<small>sound design · original music · mix creative</small></a>
  <nav class="desktop-nav" aria-label="primary">
    {links.map((l) => (
      <a href={l.href} aria-current={current === l.label ? 'page' : undefined}>{l.label}</a>
    ))}
    <button id="soundToggle" type="button" aria-pressed="false" aria-label="sound off — unmute" title="sound off — unmute" disabled>
      <span></span><span></span><span></span><span></span><span></span>
    </button>
  </nav>
  <div class="mobile-controls">
    <button id="soundToggleMobile" type="button" aria-pressed="false" aria-label="sound off — unmute" title="sound off — unmute" disabled>
      <span></span><span></span><span></span><span></span><span></span>
    </button>
    <button id="navToggle" type="button" aria-expanded="false" aria-controls="mobileNav" aria-label="open menu">
      <span class="bars" aria-hidden="true"><span></span><span></span></span>
      <span class="cross" aria-hidden="true">&#10005;</span>
    </button>
  </div>
</header>

<div id="mobileNav" aria-hidden="true">
  <nav aria-label="main menu">
    <ol>
      {links.map((l, i) => (
        <li>
          <a href={l.href} aria-current={current === l.label ? 'page' : undefined}>
            <span class="n">{pad(i + 1)}</span>
            {l.label}
          </a>
        </li>
      ))}
    </ol>
  </nav>
</div>

<script>
  import { initMobileNav } from '../scripts/mobile-nav';
  import { initHeaderScroll } from '../scripts/header-scroll';
  import { initSoundControl } from '../scripts/sound-control';
  initMobileNav();
  initHeaderScroll();
  initSoundControl();
</script>
