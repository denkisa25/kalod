---
// CR-16 (docs/change-requests/cr-001-addendum-and-session.md) — "the room":
// a fixed, self-hosted, duotoned ground for /work, /about, /contacts, /404.
// Never used on the opener, home feed, or video player — those stay black
// ("the cinema"). Generated by scripts/duotone-pattern.mjs; do not hand-edit
// bgr-duotone.webp or pattern-color.json, regenerate via the script.
//
// --pattern-bottom is sampled from the generated image's own bottom row,
// not a guessed literal — it's scoped to this component, not :root, per
// TOKEN-GUARD/D7 (no new brand colour token without sign-off).
import patternColor from '../data/pattern-color.json';
---

<div class="heritage-bg" style={`--pattern-bottom: ${patternColor.bottomColor}`}></div>

<style>
  .heritage-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-color: var(--pattern-bottom);
    background-image: url('/patterns/bgr-duotone.webp');
    background-repeat: repeat-x;
    background-position: top center;
  }
  /* D5 — tinted, subtle ground: text legibility wins over a near-raw
     legacy look. Translated from the addendum's rgba(11,11,13,.55)
     literal per TOKEN-GUARD. */
  .heritage-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: color-mix(in srgb, var(--color-bg) 55%, transparent);
  }
</style>
